# DigitalOcean
DO_TOKEN=replace_me
DO_REGION=nyc3
DO_DROPLET_SIZE=s-2vcpu-4gb
DO_SSH_KEY_FINGERPRINT=replace_me

# Optional DNS
DO_ENABLE_DNS=false
DO_DOMAIN=example.com
DO_SUBDOMAIN=tak

# Runtime
TAK_FQDN=tak.example.com
TAK_ADMIN_EMAIL=ops@example.com
TAK_SMOKE_TEST_TIMEOUT=15
TAK_SERVICE_PORT=8089
TAK_HEALTH_URL=

# Paths
TAK_MANUAL_STAGING_DIR=/opt/tak/manual
TAK_BACKUP_DIR=/var/backups/tak
