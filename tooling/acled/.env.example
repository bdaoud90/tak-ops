# Required ACLED OAuth + API endpoints
ACLED_TOKEN_URL=https://example-auth.local/oauth/token
ACLED_EVENTS_URL=https://example-api.local/acled/events
ACLED_CLIENT_ID=replace-me
ACLED_CLIENT_SECRET=replace-me

# Optional OAuth fields
ACLED_AUDIENCE=
ACLED_SCOPE=

# State + output storage
ACLED_STATE_DIR=tooling/acled/state
# Defaults to ACLED_STATE_DIR when unset
ACLED_OUTPUT_DIR=tooling/acled/state

# API behavior
ACLED_DATE_FROM_PARAM=event_date__gte
ACLED_DATE_TO_PARAM=event_date__lte
ACLED_PAGE_SIZE=500
ACLED_MAX_PAGES=200
ACLED_TIMEOUT_SECONDS=30
ACLED_VERIFY_TLS=true
ACLED_DEFAULT_LOOKBACK_DAYS=7
ACLED_LOG_LEVEL=INFO
